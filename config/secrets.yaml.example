# ============================================
# 密钥配置模板
# 复制此文件为 secrets.yaml 并填入真实密钥
# 注意: secrets.yaml 不会被提交到Git
# ============================================

# Tushare Token (可选)
tushare_token: "your_tushare_token_here"

# 券商API配置 (实盘交易用)
broker:
  # QMT配置
  qmt:
    account: ""
    password: ""
  
  # CTP配置 (期货)
  ctp:
    userid: ""
    password: ""
    brokerid: ""
    td_address: ""
    md_address: ""
  
  # Interactive Brokers (美股)
  ib:
    host: "127.0.0.1"
    port: 7497
    client_id: 1

# 钉钉通知
dingtalk:
  webhook: "https://oapi.dingtalk.com/robot/send?access_token=xxx"
  secret: ""
