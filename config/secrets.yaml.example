# ============================================
# 密钥配置模板
# 复制此文件为 secrets.yaml 并填入真实密钥
# 注意: secrets.yaml 不会被提交到Git
# ============================================

# Tushare Token (可选)
tushare_token: "your_tushare_token_here"

# 券商API配置 (实盘交易用)
broker:
  # QMT配置
  qmt:
    account: ""
    password: ""
  
  # CTP配置 (期货)
  ctp:
    userid: ""
    password: ""
    brokerid: "9999"
    app_id: "simnow_client_test"
    auth_code: "0000000000000000"
    # SimNow: tcp://180.168.146.187:10001/10011
    # SimNow 7x24: tcp://182.254.243.31:40001/40011 or 30001/30011
    td_address: "tcp://182.254.243.31:40001"
    md_address: "tcp://182.254.243.31:40011"
  
  # Interactive Brokers (美股)
  ib:
    host: "127.0.0.1"
    port: 7497
    client_id: 1

# 钉钉通知
# 1. 在钉钉群 → 群设置 → 智能群助手 → 添加机器人 → 自定义
# 2. 复制 Webhook 地址到下方 webhook 字段
# 3. 如果启用了"加签"安全设置，把秘钥填入 secret 字段
dingtalk:
  webhook: "https://oapi.dingtalk.com/robot/send?access_token=xxx"
  secret: ""
